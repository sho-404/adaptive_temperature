# Python virtual environments
venv/
.venv/
env/
ENV/

# Python cache
__pycache__/
*.py[cod]
*$py.class

# Environment / secrets
.env
.env.*
*.env

# macOS
.DS_Store

# Downloaded source papers for ShroomCap — large PDFs, regenerable, not for git
**/papers/

# Legacy reference folder — kept locally, never committed
/legacy/

# Generated artifacts — large, regenerated by the pipeline (data/ holds
# pairs jsonl + cached feature tensors; only small summaries belong in git).
*.pt
/data/*.jsonl
/data/*.checkpoint.json
/data/*.skipped.jsonl
/data/*.readable.txt
/data/*.tmp
/data/checkpoints/

# IDE/editor
.vscode/
.idea/

# Jupyter
.ipynb_checkpoints/

# Logs
*.log

# Build/dist
build/
dist/
*.egg-info/

# Node, if your project has frontend stuff
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
paper_overleaf/
template_overleaf/
