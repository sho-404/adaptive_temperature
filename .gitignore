# Python virtual environments
venv/
.venv/
env/
ENV/

# Python cache
__pycache__/
*.py[cod]
*$py.class

# Environment / secrets
.env
.env.*
*.env

# macOS
.DS_Store

# Downloaded source papers for ShroomCap — large PDFs, regenerable, not for git
**/papers/

# Legacy reference folder — kept locally, never committed
/legacy/

# Generated artifacts — regenerated by the pipeline on the run machine.
# Track only small summary JSONs (e.g. results/<task>/fixed_<lang>.json).
*.pt
**/datasets/*.jsonl
**/datasets/*.checkpoint.json
**/datasets/*.skipped.jsonl
**/datasets/*.tmp
**/results/**/*.jsonl

# IDE/editor
.vscode/
.idea/

# Jupyter
.ipynb_checkpoints/

# Logs
*.log

# Build/dist
build/
dist/
*.egg-info/

# Node, if your project has frontend stuff
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*